{
  "opencollection": "1.0.0",
  "info": {
    "name": "Runloop API Keys API",
    "version": "0.1"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "apikeys",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Create API Key.",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.runloop.ai/v1/apikeys",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a new API key for the authenticated account. Use a standard API key (ak_) or a restricted key (rk_) with RESOURCE_TYPE_ACCOUNT write scope."
        }
      ]
    },
    {
      "info": {
        "name": "restricted_keys",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Create a restricted API key.",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.runloop.ai/v1/restricted_keys",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a restricted API key with specific resource scopes. Use a standard API key (ak_) or a restricted key (rk_) with RESOURCE_TYPE_ACCOUNT write scope."
        }
      ]
    }
  ],
  "bundled": true
}